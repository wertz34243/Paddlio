{
  "name": "paddlio",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:rls": "node scripts/check-rls.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:beta": "node scripts/check-encoding.mjs && node scripts/check-rls.mjs && node scripts/check-bundle-budget.mjs && node scripts/check-a11y.mjs && node scripts/beta-blocker-check.mjs",
    "test": "vitest run src",
    "test:unit": "vitest run src",
    "test:e2e": "playwright test",
    "test:e2e:roles": "playwright test tests/e2e/roles-and-sync.spec.ts",
    "preview": "vite preview",
    "seed:development": "node scripts/seed-development-testprofile.mjs"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@supabase/supabase-js": "^2.45.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
